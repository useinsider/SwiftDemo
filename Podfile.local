install! 'cocoapods',
  warn_for_unused_master_specs_repo: false

platform :ios, '13.0'
use_frameworks!

SDK_BUILD_DIR = ENV.fetch('SDK_BUILD_DIR')

target 'ExamplePods' do
  pod 'InsiderMobile', :podspec => "#{SDK_BUILD_DIR}/InsiderMobile/outputs/InsiderMobile.local.podspec"
  pod 'InsiderGeofence', :podspec => "#{SDK_BUILD_DIR}/InsiderGeofence/outputs/InsiderGeofence.local.podspec"
  pod 'InsiderWebView', :podspec => "#{SDK_BUILD_DIR}/InsiderWebView/outputs/InsiderWebView.local.podspec"
end

target 'InsiderNotificationServicePods' do
  pod 'InsiderMobileAdvancedNotification'
end

target 'InsiderNotificationContentPods' do
  pod 'InsiderMobileAdvancedNotification'
end
