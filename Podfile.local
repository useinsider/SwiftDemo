install! 'cocoapods',
  warn_for_unused_master_specs_repo: false

platform :ios, '13.0'
use_frameworks!

target 'ExamplePods' do
  pod 'InsiderMobile', :podspec => "build/InsiderMobile/outputs/InsiderMobile.podspec"
  pod 'InsiderGeofence', :podspec => "build/InsiderGeofence/outputs/InsiderGeofence.podspec"
  pod 'InsiderWebView', :podspec => "build/InsiderWebView/outputs/InsiderWebView.podspec"
end

target 'InsiderNotificationServicePods' do
  pod 'InsiderMobileAdvancedNotification'
end

target 'InsiderNotificationContentPods' do
  pod 'InsiderMobileAdvancedNotification'
end
